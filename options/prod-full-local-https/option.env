OPTION_NAME=prod-full-local-https
PUBLIC_SCHEME=https
PUBLIC_HOST=localhost
PUBLIC_PORT=8443
PUBLIC_ORIGIN=https://localhost:8443
AUTH_COOKIE_SECURE=true
UI_RUNTIME_MODE=nginx-static
PRODUCTION_LIKE_UI=true
GRAPHRAG_MODE=disabled
GRAPHRAG_ENABLED=false
EDGE_CONTAINER_PORT=8443
LOCAL_TLS_TRUST_REQUIRED=false
