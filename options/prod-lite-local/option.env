OPTION_NAME=prod-lite-local
OPTION_KIND=compose-stack

PUBLIC_SCHEME=http
PUBLIC_HOST=localhost
PUBLIC_PORT=8080
PUBLIC_ORIGIN=http://localhost:8080
EDGE_CONTAINER_PORT=8080

UI_RUNTIME_MODE=nginx-static
PRODUCTION_LIKE_UI=true
OBSERVABILITY_ENABLED=false

GRAPHRAG_MODE=enabled
GRAPHRAG_ENABLED=true
GRAPHRAG_DEADLINE_MS=3000
GRAPHRAG_MOCK_ENABLED=false

QUICK_ANSWER_A1_PROVIDER_ORDER=gemini-flash-lite,openai-mini,local
QUICK_ANSWER_A1_TIMEOUT_MS=6000
QUICK_ANSWER_A1_FAIL_OPEN=true

PLAN_BY_AI_ENABLED=true
PLAN_BY_AI_SHADOW_ENABLED=false

LOCAL_AI_MODEL=planner
LOCAL_AI_BASE_MODEL=qwen2.5:1.5b-instruct
LOCAL_AI_MODELFILE_HOST=../../infra/spike/ollama/Modelfile.planner-lite
LOCAL_AI_PREPARE_MODEL=true
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_NUM_PARALLEL=1
OLLAMA_KEEP_ALIVE=2m

GRPC_MAX_WORKERS=2
INGESTION_MAX_RETRIES=2
KAFKA_NUM_PARTITIONS=4
MANAGEMENT_TRACING_ENABLED=false
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=0.0
ADMIN_OBS_UI_DASHBOARD=
ADMIN_OBS_UI_PROMETHEUS=
ADMIN_OBS_UI_ZIPKIN=
ADMIN_OBS_UI_LOGS=

# Required secret placeholders. Keep tracked values empty; put real local
# values in untracked options/prod-lite-local/.env.
POSTGRES_PASSWORD=
ACCOUNT_DB_PASSWORD=
PROMPT_DB_PASSWORD=
GRAPHRAG_DB_PASSWORD=
VALKEY_PASSWORD=
VALKEY_COMMAND_TIMEOUT_MS=2000
VALKEY_CONNECT_TIMEOUT_MS=2000
AUTH_JWT_PRIVATE_KEY_PEM=
AUTH_JWT_PUBLIC_KEYS_PEM=
GATEWAY_INTERNAL_PRIVATE_KEY_PEM=
GATEWAY_INTERNAL_PUBLIC_KEYS_PEM=
ACCOUNT_INTERNAL_SERVICE_TOKEN=
TENANT_NAMESPACE_HMAC_KEY=
