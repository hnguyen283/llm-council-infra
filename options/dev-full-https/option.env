OPTION_NAME=dev-full-https
PUBLIC_SCHEME=https
PUBLIC_HOST=localhost
PUBLIC_PORT=4200
PUBLIC_ORIGIN=https://localhost:4200
AUTH_COOKIE_SECURE=true
UI_RUNTIME_MODE=angular-dev-server
PRODUCTION_LIKE_UI=false
UI_DEV_TLS_ARGS=--ssl --ssl-cert /run/tls/cert.pem --ssl-key /run/tls/key.pem
LOCAL_TLS_TRUST_REQUIRED=false
GRAPHRAG_MODE=disabled
GRAPHRAG_ENABLED=false
