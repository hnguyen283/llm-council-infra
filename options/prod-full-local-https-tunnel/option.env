OPTION_NAME=prod-full-local-https-tunnel
PUBLIC_SCHEME=https
PUBLIC_HOST=llm.welllifeapp.com
PUBLIC_PORT=443
PUBLIC_ORIGIN=https://llm.welllifeapp.com
AUTH_COOKIE_SECURE=true
CORS_ALLOWED_ORIGINS=https://llm.welllifeapp.com
UI_RUNTIME_MODE=nginx-static
PRODUCTION_LIKE_UI=true
GRAPHRAG_MODE=disabled
GRAPHRAG_ENABLED=false
EDGE_CONTAINER_PORT=8080
EDGE_HTTP_HOST_PORT=8080
EDGE_FORWARDED_PROTO=https
EDGE_FORWARDED_PORT=443
TLS_TERMINATION=cloudflare
TUNNEL_ENABLED=true
LOCAL_SERVICE_MAPPING=http://localhost:8080
