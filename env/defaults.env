# Versioned non-secret defaults for the standardized option model.
# Secrets stay in untracked env/workspace.env, env/local.user.override.env, or
# future Compose secret files.

COMPOSE_PROJECT_NAME=llm-council-standard
LLM_COUNCIL_IMAGE_REGISTRY=local/llm-council
IMAGE_TAG=local

PUBLIC_HOST=localhost
PUBLIC_HOST_BIND=127.0.0.1
PUBLIC_HTTP_PORT=8080
PUBLIC_HTTPS_PORT=8443
PUBLIC_EDGE_PATH=/

POSTGRES_USER=llm_admin
POSTGRES_DB=llm_council
ACCOUNT_DB_USER=account_app
PROMPT_DB_USER=prompt_app
GRAPHRAG_DB_USER=graphrag_app

LOCAL_PG_HOST_BIND=127.0.0.1
LOCAL_VALKEY_HOST_BIND=127.0.0.1
OBSERVABILITY_HOST_BIND=127.0.0.1
HTTPS_FACADE_HOST_BIND=127.0.0.1
HTTPS_FACADE_PORT=8443
HTTPS_CERT_DIR=../ssl

AUTH_JWT_SIGNING_KID=auth-2026-05
AUTH_JWT_ISSUER=https://auth.llm-council.local/
AUTH_JWT_AUDIENCE=llm-council-ui
GATEWAY_INTERNAL_KID=internal-2026-05
GATEWAY_INTERNAL_ISSUER=internal:api-gateway
GATEWAY_INTERNAL_AUDIENCE=internal
GATEWAY_INTERNAL_TTL_SECONDS=3600
ACCOUNT_INTERNAL_AUTH_ENABLED=false

AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=Strict
AUTH_COOKIE_PATH=/auth
AUTH_COOKIE_DOMAIN=
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:4200,http://localhost:4201

PLAN_BY_AI_ENABLED=true
PLAN_BY_AI_SHADOW_ENABLED=true
STANDARDIZED_PROMPT_ENABLED=false
STANDARDIZED_PROMPT_SHADOW_ENABLED=false
STANDARDIZED_PROMPT_FAIL_CLOSED=false
STANDARDIZED_PROMPT_CAPTURE_ARTIFACTS=false
STANDARDIZED_PROMPT_AUGMENTATION_ENABLED=false

GRAPHRAG_MODE=disabled
GRAPHRAG_ENABLED=false
GRAPHRAG_TARGET=graphrag-retrieval-service:50051
GRAPHRAG_DEADLINE_MS=5000
GRAPHRAG_MOCK_ENABLED=false

LOCAL_AI_MODEL=planner
ORCHESTRATOR_CONCURRENCY_MAX_JOBS=25
LOCAL_AI_WORKER_ID=local-ai-laptop
LOCAL_AI_HEARTBEAT_ENABLED=true
LOCAL_AI_HEARTBEAT_INTERVAL_MS=15000
LOCAL_AI_HEARTBEAT_TTL_MS=60000
LOCAL_AI_HEARTBEAT_CAPACITY=1
LOCAL_AI_HEARTBEAT_PROBE_TIMEOUT_MS=2000

OBSERVABILITY_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://zipkin:9411
OTEL_SERVICE_NAME=llm-council
OTEL_RESOURCE_ATTRIBUTES=service.namespace=llm-council,deployment.environment=local
OBSERVABILITY_RETENTION_MODE=local-30d
EXTERNAL_AI_ROUTE_MODE=direct
CLOUDFLARED_TUNNEL_TOKEN=

LOG_DIR_HOST=../../logs
ADMIN_DASHBOARD_BASE_URL=/admin/observability
ADMIN_OBS_UI_DASHBOARD=
ADMIN_OBS_UI_PROMETHEUS=
ADMIN_OBS_UI_ZIPKIN=
ADMIN_OBS_UI_LOGS=
ADMIN_VICTORIALOGS_BASE_URL=http://victorialogs:9428
ADMIN_VICTORIALOGS_TIMEOUT_MS=5000

AUTH_GOOGLE_CLIENT_ID=6840074201-mnnmft8h60lfpbuh1abmcnlejf28acu7.apps.googleusercontent.com
AUTH_GOOGLE_ALLOWED_DOMAINS=welllifeapp.com,llm.welllifeapp.com,gmail.com,
